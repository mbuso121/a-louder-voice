# ── REQUIRED ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/myDatabase?retryWrites=true&w=majority

# Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=generate_a_long_random_string_here

# ── ENVIRONMENT ───────────────────────────────────────────
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=https://aloudervoice.co.za,https://www.aloudervoice.co.za

# ── SERVER ────────────────────────────────────────────────
PORT=5000

# ── CLIENT URL (used in password reset email links) ───────
CLIENT_URL=https://www.aloudervoice.co.za

# ── EMAIL ─────────────────────────────────────────────────
# Use Gmail App Password (NOT your real password)
# 1. Enable 2FA on Gmail
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate app password → copy the 16-char code (no spaces)
EMAIL_USER=your@gmail.com
EMAIL_PASS=abcdefghijklmnop
CONTACT_EMAIL=your@gmail.com

# ── CLOUDINARY (image & video uploads) ───────────────────
# Free account at https://cloudinary.com
# Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
